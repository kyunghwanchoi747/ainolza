/* AI놀자 Landing — Apple-style Liquid Glass
   Drop-in CSS module. Pair with LandingPage.tsx. */

/* ─── Design tokens ─────────────────────────────────────────── */
.root {
  --brand: #D4756E;
  --brand-dark: #B8604F;
  --brand-light: #FDF0EC;
  --ink: #1a1a1a;
  --body: #515154;
  --sub: #86868B;
  --hint: #B0B0B5;
  --bg: #ffffff;
  --bg-soft: #F5F5F7;
  --glass-bg: linear-gradient(135deg, rgba(255,255,255,0.75) 0%, rgba(255,255,255,0.45) 100%);
  --glass-border: 1px solid rgba(255,255,255,0.6);
  --glass-shadow:
    0 1px 0 0 rgba(255,255,255,0.9) inset,
    0 -1px 0 0 rgba(255,255,255,0.25) inset,
    0 8px 32px -8px rgba(31,38,135,0.12),
    0 2px 8px -2px rgba(0,0,0,0.06);
  --glass-shadow-hover:
    0 1px 0 0 rgba(255,255,255,0.9) inset,
    0 -1px 0 0 rgba(255,255,255,0.25) inset,
    0 24px 48px -12px rgba(31,38,135,0.2),
    0 8px 16px -4px rgba(0,0,0,0.08);
  --hair: rgba(0,0,0,0.08);
  --kakao: #FEE500;
  --radius: 24px;
  font-family: Pretendard, -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
  letter-spacing: -0.015em;
  color: var(--ink);
  background: var(--bg);
}
.root *, .root *::before, .root *::after { box-sizing: border-box; }
.root button { font-family: inherit; }
.root a { text-decoration: none; cursor: pointer; }

/* ─── Reusable glass card ────────────────────────────────────── */
.glass {
  position: relative;
  isolation: isolate;
  background: var(--glass-bg);
  backdrop-filter: blur(30px) saturate(180%);
  -webkit-backdrop-filter: blur(30px) saturate(180%);
  border: var(--glass-border);
  box-shadow: var(--glass-shadow);
  border-radius: var(--radius);
  overflow: hidden;
}
/* Liquid sheen overlays — pure CSS, no pseudo conflict needed */
.sheen::before, .sheen::after {
  content: '';
  position: absolute; inset: 0;
  border-radius: inherit;
  pointer-events: none;
  mix-blend-mode: overlay;
}
.sheen::before {
  background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0) 35%);
}
.sheen::after {
  background: linear-gradient(115deg, transparent 40%, rgba(255,255,255,0.35) 50%, transparent 62%);
}

/* ─── Buttons ────────────────────────────────────────────────── */
.btnCoral {
  background: var(--brand); color: #fff; border: 0;
  padding: 16px 30px; border-radius: 9999px;
  font-size: 15px; font-weight: 700; letter-spacing: -0.01em;
  cursor: pointer; display: inline-flex; align-items: center; gap: 10px;
  box-shadow: 0 8px 20px -8px rgba(212,117,110,0.35);
  transition: all .25s; white-space: nowrap;
}
.btnCoral:hover {
  background: var(--brand-dark);
  transform: translateY(-2px);
  box-shadow: 0 18px 36px -10px rgba(212,117,110,0.5);
}
.btnCoral.sm { padding: 12px 22px; font-size: 13px; }
.btnGhost {
  background: transparent; color: var(--ink);
  border: 1px solid var(--hair);
  padding: 16px 30px; border-radius: 9999px;
  font-size: 15px; font-weight: 600; letter-spacing: -0.01em;
  cursor: pointer; display: inline-flex; align-items: center; gap: 10px;
  transition: all .25s; white-space: nowrap;
}
.btnGhost:hover { background: rgba(0,0,0,0.04); }
.btnGhost.sm { padding: 12px 22px; font-size: 13px; }

/* ─── Header ─────────────────────────────────────────────────── */
.header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--hair);
}
.headerInner {
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
  height: 64px; display: flex; align-items: center;
  justify-content: space-between; gap: 24px;
}
.logo {
  font-size: 20px; font-weight: 800; color: var(--brand);
  letter-spacing: -0.035em; white-space: nowrap;
}
.nav { display: flex; gap: 30px; font-size: 13.5px; white-space: nowrap; }
.nav a { color: var(--ink); font-weight: 500; transition: color .2s; }
.nav a:hover { color: var(--brand); }
.headerRight { display: flex; gap: 10px; align-items: center; white-space: nowrap; }
.loginLink { font-size: 13px; color: var(--body); font-weight: 500; }
.signupBtn {
  background: var(--brand); color: #fff; border: 0;
  padding: 9px 18px; border-radius: 9999px;
  font-size: 13px; font-weight: 700; letter-spacing: -0.01em;
  cursor: pointer;
}
.signupBtn:hover { background: var(--brand-dark); }

/* ─── Hero ───────────────────────────────────────────────────── */
.hero {
  position: relative; overflow: hidden;
  padding: 120px 24px 100px; text-align: center;
  background: #ffffff;
}
.hero.softgray { background: #F5F5F7; }
.hero.warm { background: linear-gradient(180deg, #FFFFFF 0%, #FDF8F5 100%); }

.orb { position: absolute; border-radius: 50%; pointer-events: none; }
.orb1 {
  width: 720px; height: 720px;
  background: radial-gradient(circle, #FFB4A8 0%, #FADAD5 40%, transparent 70%);
  opacity: 0.65; filter: blur(60px);
  top: -240px; left: 50%; transform: translateX(-50%);
}
.orb2 {
  width: 460px; height: 460px;
  background: radial-gradient(circle, #B5C7F7 0%, #D4DEF9 50%, transparent 75%);
  opacity: 0.55; filter: blur(70px);
  bottom: -140px; right: -80px;
}
.orb3 {
  width: 380px; height: 380px;
  background: radial-gradient(circle, #FCE4B8 0%, #FFF0D4 50%, transparent 75%);
  opacity: 0.5; filter: blur(60px);
  top: 38%; left: -120px;
}
.orb4 {
  width: 320px; height: 320px;
  background: radial-gradient(circle, #E4C8F5 0%, #F0DFFA 50%, transparent 75%);
  opacity: 0.45; filter: blur(70px);
  top: 15%; right: -80px;
}
.heroInner { position: relative; max-width: 900px; margin: 0 auto; }

.pill {
  position: relative; isolation: isolate; overflow: hidden;
  display: inline-flex; align-items: center; gap: 10px;
  padding: 10px 20px;
  background: linear-gradient(135deg, rgba(255,255,255,0.7) 0%, rgba(255,255,255,0.4) 100%);
  border: 1px solid rgba(255,255,255,0.8);
  color: var(--brand-dark);
  border-radius: 9999px;
  font-size: 13px; font-weight: 600; letter-spacing: -0.01em;
  margin-bottom: 32px; white-space: nowrap;
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  box-shadow: 0 1px 0 rgba(255,255,255,0.9) inset, 0 4px 14px -2px rgba(212,117,110,0.18);
}
.pill::before {
  content: ''; position: absolute; inset: 0; border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, transparent 50%);
  mix-blend-mode: overlay;
}
.pill > span { position: relative; }

.heroTitle {
  font-size: 84px; font-weight: 800; line-height: 1.04;
  margin: 0 0 28px; letter-spacing: -0.045em; color: var(--ink);
}
.hoverPop {
  display: inline-block;
  transition: transform .28s cubic-bezier(.34,1.56,.64,1), text-shadow .28s;
  cursor: default;
}
.hoverPop:hover {
  transform: translateY(-6px) scale(1.02);
  text-shadow: 0 14px 26px rgba(0,0,0,0.12);
}
.heroLead {
  color: var(--body); font-size: 21px;
  margin: 0 auto 48px; line-height: 1.55; max-width: 620px;
  font-weight: 400; letter-spacing: -0.012em;
}
.ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

.browser {
  margin: 80px auto 0; max-width: 760px;
  padding: 6px; border-radius: 26px;
}
.browserBar {
  position: relative;
  background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.7) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 20px; padding: 14px 20px;
  display: flex; align-items: center; gap: 14px;
  text-align: left; border: 1px solid rgba(255,255,255,0.7);
  box-shadow: 0 1px 0 rgba(255,255,255,0.9) inset;
}
.dots { display: flex; gap: 6px; }
.dots span { width: 11px; height: 11px; border-radius: 50%; }
.url { font-size: 12px; color: var(--sub); font-family: ui-monospace, monospace; }
.secure {
  font-size: 11px; color: var(--sub);
  display: flex; align-items: center; gap: 6px; margin-left: auto;
}

/* ─── Social proof ───────────────────────────────────────────── */
.social {
  padding: 64px 24px; background: var(--bg);
  border-top: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
}
.statGrid {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
}
.stat { text-align: center; padding: 12px 8px; }
.stat + .stat { border-left: 1px solid var(--hair); }
.statValue {
  font-size: 40px; font-weight: 800; color: var(--ink);
  margin: 0 0 6px; letter-spacing: -0.035em; line-height: 1;
}
.statValue small { font-size: 16px; color: var(--hint); font-weight: 600; margin-left: 2px; }
.statLabel { font-size: 13px; color: var(--sub); margin: 0; font-weight: 500; }

/* ─── Section heading ────────────────────────────────────────── */
.section { padding: 120px 24px; background: var(--bg); }
.sectionAlt { padding: 120px 24px; background: var(--bg-soft); position: relative; overflow: hidden; }
.sectionAlt::before {
  content: ''; position: absolute;
  width: 600px; height: 600px; border-radius: 50%;
  background: #FADAD5; opacity: 0.4; filter: blur(140px);
  top: -200px; right: -200px; pointer-events: none;
}
.container { max-width: 1200px; margin: 0 auto; position: relative; }
.headingCenter { text-align: center; margin-bottom: 64px; }
.eyebrow {
  font-size: 13px; font-weight: 600; color: var(--brand);
  letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 14px;
}
.h2 {
  font-size: 52px; font-weight: 800;
  margin: 0 0 14px; letter-spacing: -0.035em;
  color: var(--ink); line-height: 1.1;
}
.sectionLead {
  color: var(--body); font-size: 18px;
  margin: 0; line-height: 1.55; letter-spacing: -0.01em;
}

/* ─── Course cards ───────────────────────────────────────────── */
.courseGrid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
}
.courseCard {
  display: flex; flex-direction: column;
  transition: all .4s cubic-bezier(.4,0,.2,1);
  cursor: pointer;
}
.courseCard:hover {
  transform: translateY(-8px) scale(1.01);
  box-shadow: var(--glass-shadow-hover);
}
.hotBadge {
  position: absolute; top: 16px; right: 16px; z-index: 2;
  background: var(--brand); color: #fff;
  padding: 5px 12px; font-size: 10px; font-weight: 700;
  letter-spacing: 0.14em; border-radius: 9999px;
}
.courseHead {
  height: 140px;
  background: linear-gradient(135deg, #FDF0EC 0%, #F5F5F7 100%);
  position: relative; overflow: hidden;
  display: flex; align-items: flex-end; padding: 20px;
}
.courseHead::before {
  content: ''; position: absolute; right: -30px; top: -30px;
  width: 160px; height: 160px; border-radius: 50%;
  background: var(--brand); opacity: 0.12; filter: blur(20px);
}
.courseHead::after {
  content: ''; position: absolute; right: 30px; bottom: -20px;
  width: 80px; height: 80px; border-radius: 50%;
  background: rgba(255,255,255,0.6); backdrop-filter: blur(10px);
}
.courseBadge {
  position: relative; display: inline-block;
  padding: 6px 14px;
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  color: var(--brand-dark); border-radius: 9999px;
  font-size: 12px; font-weight: 700; letter-spacing: -0.01em;
  border: 1px solid rgba(255,255,255,0.5); white-space: nowrap;
}
.courseBody {
  padding: 28px 26px; display: flex; flex-direction: column; flex: 1;
  position: relative;
}
.courseTitle {
  font-size: 22px; font-weight: 800; margin: 0 0 12px;
  letter-spacing: -0.025em; color: var(--ink); line-height: 1.3;
}
.courseDesc {
  font-size: 14px; color: var(--body); line-height: 1.65;
  margin: 0 0 22px; flex: 1; letter-spacing: -0.005em;
}
.courseMeta {
  display: flex; flex-direction: column; gap: 10px;
  margin-bottom: 24px; padding-bottom: 22px;
  border-bottom: 1px solid var(--hair);
}
.metaRow {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--body);
}
.metaRow svg { color: var(--brand); flex-shrink: 0; }
.priceRow { display: flex; justify-content: space-between; align-items: flex-end; }
.priceOld {
  font-size: 12px; color: var(--hint); margin: 0 0 4px;
  text-decoration: line-through; font-weight: 500;
}
.priceNow {
  font-size: 22px; font-weight: 800; color: var(--ink);
  margin: 0; letter-spacing: -0.025em;
}

/* ─── Why grid ───────────────────────────────────────────────── */
.whyHead {
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
  align-items: center; margin-bottom: 64px;
}
.whyLead { color: var(--body); font-size: 18px; margin: 0; line-height: 1.7; letter-spacing: -0.01em; }
.whyLead strong { color: var(--ink); font-weight: 700; }
.whyGrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.whyCard { padding: 32px 26px; }
.whyIcon {
  position: relative;
  width: 56px; height: 56px; border-radius: 16px;
  background: linear-gradient(135deg, rgba(212,117,110,0.2) 0%, rgba(212,117,110,0.08) 100%);
  color: var(--brand);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 22px; font-size: 26px;
  border: 1px solid rgba(255,255,255,0.6);
  box-shadow: 0 1px 0 rgba(255,255,255,0.8) inset, 0 4px 12px -2px rgba(212,117,110,0.15);
  backdrop-filter: blur(10px);
}
.whyTitle {
  position: relative;
  font-size: 18px; font-weight: 800; margin: 0 0 10px;
  color: var(--ink); letter-spacing: -0.02em;
}
.whyDesc {
  position: relative;
  font-size: 13.5px; color: var(--body);
  line-height: 1.65; margin: 0; letter-spacing: -0.005em;
}

/* ─── Reviews ────────────────────────────────────────────────── */
.reviewGrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.reviewCard {
  padding: 36px 30px 30px;
  background: linear-gradient(135deg, rgba(255,255,255,0.8) 0%, rgba(245,245,247,0.55) 100%);
  display: flex; flex-direction: column;
}
.reviewQuoteIcon { position: relative; color: var(--brand); opacity: 0.3; margin-bottom: 18px; }
.stars { position: relative; display: flex; gap: 2px; margin-bottom: 18px; color: #FFB400; }
.reviewQuote {
  position: relative;
  font-size: 15px; color: var(--ink); line-height: 1.7;
  margin: 0 0 28px; flex: 1; font-weight: 500; letter-spacing: -0.012em;
}
.reviewer {
  position: relative;
  display: flex; align-items: center; gap: 14px;
  padding-top: 22px; border-top: 1px solid var(--hair);
}
.avatar {
  width: 44px; height: 44px; border-radius: 50%;
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 800; flex-shrink: 0;
}
.reviewerName { font-size: 14px; font-weight: 700; color: var(--ink); margin: 0 0 2px; letter-spacing: -0.01em; }
.reviewerMeta { font-size: 12px; color: var(--sub); margin: 0; }
.reviewerTag {
  font-size: 10px; font-weight: 600; color: var(--brand-dark);
  background: rgba(212,117,110,0.1);
  padding: 5px 10px; border-radius: 6px; white-space: nowrap;
  border: 1px solid rgba(212,117,110,0.2);
}

/* ─── Final CTA ──────────────────────────────────────────────── */
.finalCta {
  position: relative; overflow: hidden;
  padding: 128px 24px; text-align: center;
  background: var(--bg-soft); color: var(--ink);
}
.ctaOrb1 {
  position: absolute; width: 700px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, #FFB4A8 0%, #FADAD5 45%, transparent 75%);
  opacity: 0.7; filter: blur(70px); pointer-events: none;
  top: 30%; left: 20%; transform: translate(-50%,-50%);
}
.ctaOrb2 {
  position: absolute; width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, #B5C7F7 0%, #D4DEF9 50%, transparent 75%);
  opacity: 0.55; filter: blur(80px); pointer-events: none;
  top: 50%; right: 15%;
}
.ctaOrb3 {
  position: absolute; width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, #FCE4B8 0%, #FFF0D4 50%, transparent 75%);
  opacity: 0.5; filter: blur(70px); pointer-events: none;
  bottom: -120px; left: 30%;
}
.ctaBox {
  position: relative; max-width: 780px; margin: 0 auto;
  padding: 72px 40px 60px;
}
.ctaBox > * { position: relative; }
.ctaTitle {
  font-size: 58px; font-weight: 800; margin: 0 0 24px;
  line-height: 1.05; letter-spacing: -0.04em; color: var(--ink);
}
.ctaLead {
  color: var(--body); font-size: 18px;
  margin: 0 0 44px; line-height: 1.65; letter-spacing: -0.01em;
}
.ctaMeta { margin-top: 36px; font-size: 13px; color: var(--sub); }
.ctaMeta strong { color: var(--brand-dark); font-weight: 700; }

/* ─── Footer ─────────────────────────────────────────────────── */
.footer {
  background: var(--bg); color: var(--sub);
  padding: 56px 24px 48px; text-align: center;
  border-top: 1px solid var(--hair);
}
.footerInner { max-width: 1200px; margin: 0 auto; }
.footerLogo { font-size: 18px; font-weight: 800; color: var(--brand); margin: 0 0 14px; letter-spacing: -0.03em; }
.footerLinks {
  display: flex; justify-content: center; gap: 16px;
  font-size: 13px; margin-bottom: 18px; flex-wrap: wrap;
}
.footerLinks a { color: var(--body); font-weight: 500; }
.footerLinks span { color: var(--hint); }
.footerFine { font-size: 12px; color: var(--hint); margin: 0; line-height: 1.7; }

/* ─── Responsive ─────────────────────────────────────────────── */
@media (max-width: 960px) {
  .courseGrid, .whyGrid, .reviewGrid, .statGrid { grid-template-columns: 1fr; }
  .whyHead { grid-template-columns: 1fr; gap: 24px; }
  .whyGrid { grid-template-columns: repeat(2, 1fr); }
  .heroTitle { font-size: 52px; }
  .h2, .ctaTitle { font-size: 36px; }
  .nav { display: none; }
}
