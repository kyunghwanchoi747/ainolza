#!/bin/bash
# 개인정보 파일 커밋 방지 훅
# 회원정보, 엑셀, CSV 파일이 커밋에 포함되면 차단

BLOCKED_PATTERNS=(
  "회원"
  "member"
  "Members"
  "\.xls$"
  "\.xlsx$"
  "\.csv$"
  "\.zip$"
  "개인정보"
  "credentials"
)

STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if echo "$file" | grep -qi "$pattern"; then
      echo ""
      echo "======================================"
      echo "  커밋 차단: 개인정보 파일 감지!"
      echo "======================================"
      echo ""
      echo "  차단된 파일: $file"
      echo "  매칭 패턴: $pattern"
      echo ""
      echo "  해제하려면: git reset HEAD $file"
      echo "======================================"
      echo ""
      exit 1
    fi
  done
done

exit 0
